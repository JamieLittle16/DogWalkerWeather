<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="mainContainer" prefHeight="844.0" prefWidth="390.0"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cambridge.weatherapp.dogwalkerweather.controller.RootController">

    <top>
        <HBox alignment="CENTER" style="-fx-background-color: #2D3E50; -fx-padding: 15px;">
            <Label text="Raining Dogs" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #ffffff; -fx-padding: 15px 0 25px 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <Button text="Home" onAction="#onHomeClicked"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-text-fill: #3bc8c8; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>

            <Button text="Settings" onAction="#onSettingsClicked"
                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>