<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import cambridge.weatherapp.dogwalkerweather.controller.ComboWeatherChart?>


<VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #3bc8c8; -fx-padding: 30px;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cambridge.weatherapp.dogwalkerweather.controller.HomeController">
   <VBox prefHeight="20.0" prefWidth="100.0">
      <children>
         <Button alignment="CENTER_LEFT" mnemonicParsing="false" onAction="#onLocationClicked" text="Button" />
      </children>
   </VBox>

    <HBox alignment="CENTER" spacing="10.0">
        <Label fx:id="locationLabel" style="-fx-text-fill: white;" styleClass="title-2" text="Cambridge" />
    </HBox>

    <Label fx:id="tempLabel" style="-fx-text-fill: white; -fx-font-size: 72px; -fx-font-weight: bold;" styleClass="title-1" text="Waiting..." />

    <VBox alignment="CENTER" prefHeight="150" prefWidth="330" style="-fx-border-color: blue;" styleClass="card, elevated-1">
<!--        <Label styleClass="text-muted" text="Bar Chart Goes Here" />-->
        <ComboWeatherChart />
    </VBox>

    <VBox alignment="CENTER" spacing="15.0">
        <HBox alignment="CENTER" spacing="15.0">
            <fx:include fx:id="UVWidget" source="HumidityCard.fxml" style="-fx-border-color: blue;" />
            <fx:include fx:id="groundWidget" source="HumidityCard.fxml" style="-fx-border-color: blue;" />
        </HBox>

        <HBox alignment="CENTER" spacing="15.0">
            <fx:include fx:id="humidityWidget" source="HumidityCard.fxml" style="-fx-border-color: blue;" />
            <fx:include fx:id="windspeedWidget" source="HumidityCard.fxml" style="-fx-border-color: blue;" />
        </HBox>
    </VBox>

</VBox>
