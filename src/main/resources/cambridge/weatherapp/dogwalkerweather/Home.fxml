<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #3bc8c8; -fx-padding: 30px;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cambridge.weatherapp.dogwalkerweather.controller.HomeController">

    <HBox alignment="CENTER" spacing="10.0">
        <Label fx:id="locationLabel" text="Cambridge" styleClass="title-2" style="-fx-text-fill: white;" />
    </HBox>

    <Label fx:id="tempLabel" text="Waiting..." styleClass="title-1" style="-fx-text-fill: white; -fx-font-size: 72px; -fx-font-weight: bold;" />

    <VBox styleClass="card, elevated-1" prefHeight="150" prefWidth="330" alignment="CENTER">
        <Label text="Bar Chart Goes Here" styleClass="text-muted"/>
    </VBox>

    <VBox spacing="15.0" alignment="CENTER">
        <HBox alignment="CENTER" spacing="15.0">
            <fx:include fx:id="humidityWidget" source="HumidityCard.fxml" />

            <VBox styleClass="card, elevated-2" prefHeight="120.0" prefWidth="120.0" alignment="CENTER">
                <Label text="Ground" styleClass="text-muted"/>
                <Label fx:id="groundLabel" text="Wet" styleClass="title-2"/>
            </VBox>
        </HBox>

        <HBox alignment="CENTER" spacing="15.0">
            <VBox styleClass="card, elevated-2" prefHeight="120.0" prefWidth="120.0" />
            <VBox styleClass="card, elevated-2" prefHeight="120.0" prefWidth="120.0" />
        </HBox>
    </VBox>

</VBox>