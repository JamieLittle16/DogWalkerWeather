<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: #3bc8c8; -fx-padding: 30px;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cambridge.weatherapp.dogwalkerweather.controller.HomeController">

    <HBox alignment="CENTER" spacing="10.0">
        <Label fx:id="locationLabel" style="-fx-text-fill: white;" styleClass="title-2" text="Cambridge" />
    </HBox>

    <Label fx:id="tempLabel" style="-fx-text-fill: white; -fx-font-size: 72px; -fx-font-weight: bold;" styleClass="title-1" text="Waiting..." />

    <VBox alignment="CENTER" prefHeight="150" prefWidth="330" styleClass="card, elevated-1">
        <Label styleClass="text-muted" text="Bar Chart Goes Here">
         <graphic>
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="DODGERBLUE" height="200.0" stroke="BLACK" strokeType="INSIDE" width="200.0" />
         </graphic></Label>
    </VBox>

    <VBox alignment="CENTER" spacing="15.0">
        <HBox alignment="CENTER" spacing="15.0">
            <fx:include fx:id="humidityWidget" source="HumidityCard.fxml" />

            <VBox alignment="CENTER" prefHeight="120.0" prefWidth="120.0" styleClass="card, elevated-2">
                <Label styleClass="text-muted" text="Ground" />
                <Label fx:id="groundLabel" styleClass="title-2" text="Wet" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER" spacing="15.0">
            <VBox prefHeight="120.0" prefWidth="120.0" styleClass="card, elevated-2" />
            <VBox prefHeight="120.0" prefWidth="120.0" styleClass="card, elevated-2" />
        </HBox>
    </VBox>

</VBox>
