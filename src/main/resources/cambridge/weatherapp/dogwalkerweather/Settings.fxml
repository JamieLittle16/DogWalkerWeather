<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane style="-fx-background-color: #3bc8c8;"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="cambridge.weatherapp.dogwalkerweather.controller.SettingsController">

    <VBox spacing="20.0">
        <padding>
            <Insets top="20.0" right="30.0" bottom="20.0" left="30.0"/>
        </padding>

        <HBox alignment="CENTER_LEFT">
            <Button text="&lt;" onAction="#onBackClicked"
                    style="-fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-background-color: #e0e0e0;"/>
        </HBox>

        <Label text="Current Location" styleClass="title-3" style="-fx-text-fill: white;"/>
        <VBox alignment="CENTER_LEFT" prefHeight="80.0"
              styleClass="card, elevated-2"
              style="-fx-background-color: #e0e0e0; -fx-padding: 20; -fx-background-radius: 15;">
            <Label fx:id="currentLocationLabel" styleClass="title-2" text="Loading..."/>
        </VBox>

        <Separator style="-fx-background-color: #2D3E50;"/>

        <Label text="Saved Locations" styleClass="title-3" style="-fx-text-fill: white;"/>
        <ListView fx:id="locationsList" VBox.vgrow="ALWAYS"
                  style="-fx-background-radius: 15; -fx-background-color: transparent;" />
    </VBox>

    <Button text="+" onAction="#onAddClicked" StackPane.alignment="BOTTOM_CENTER"
            style="-fx-background-radius: 50; -fx-min-width: 60; -fx-min-height: 60; -fx-font-size: 24; -fx-background-color: #e0e0e0;">
        <StackPane.margin>
            <Insets bottom="40.0"/>
        </StackPane.margin>
    </Button>

</StackPane>